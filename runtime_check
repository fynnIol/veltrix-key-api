    local function applyDescriptionCompat(humanoid, description)
        if not humanoid or not description then
            return false
        end

        -- DevForum fixes used here:
        --   1. Never edit/apply the HumanoidDescription currently parented
        --      to the Humanoid. Always apply a fresh clone.
        --   2. Prefer the supplied ClientServer method, then Roblox's newer
        --      async reset/apply methods as fallbacks.
        --   3. Rebuild attachment welds after client-side appearance edits.
        local workingDescription = description:Clone()
        local applied = false

        local function tryApply(methodName, withVerification)
            local found, method = pcall(function()
                return humanoid[methodName]
            end)

            if not found or type(method) ~= "function" then
                return false
            end

            local ok = pcall(function()
                if withVerification then
                    method(
                        humanoid,
                        workingDescription,
                        Enum.AssetTypeVerification.ClientOnly
                    )
                else
                    method(humanoid, workingDescription)
                end
            end)

            return ok
        end

        local function descriptionLooksApplied()
            local ok, current = pcall(function()
                return humanoid:GetAppliedDescription()
            end)

            if not ok or not current then
                return false
            end

            local checked = 0
            local matches = true
            local fields = {
                "Head",
                "Torso",
                "LeftArm",
                "RightArm",
                "LeftLeg",
                "RightLeg",
                "Shirt",
                "Pants",
                "GraphicTShirt",
            }

            for _, field in ipairs(fields) do
                local wanted = tonumber(workingDescription[field]) or 0
                if wanted > 0 then
                    checked = checked + 1
                    if (tonumber(current[field]) or 0) ~= wanted then
                        matches = false
                        break
                    end
                end
            end

            current:Destroy()
            return checked == 0 or matches
        end

        local hasClientServer, clientServerMethod = pcall(function()
            return humanoid.ApplyDescriptionClientServer
        end)

        if hasClientServer and type(clientServerMethod) == "function" then
            applied = pcall(function()
                clientServerMethod(humanoid, workingDescription)
            end)
        end

        if applied then
            task.wait(0.15)
        end

        if not applied or not descriptionLooksApplied() then
            applied = tryApply("ApplyDescriptionResetAsync", true)
        end

        if not applied then
            applied = tryApply("ApplyDescriptionAsync", true)
        end

        if not applied then
            applied = tryApply("ApplyDescriptionReset", false)
        end

        if not applied then
            applied = tryApply("ApplyDescription", false)
        end

        if applied then
            task.wait(0.15)
            pcall(function()
                humanoid:BuildRigFromAttachments()
            end)
        end

        -- Some executor-only apply methods finish their asset work after the
        -- call returns, so do not destroy the clone immediately.
        task.delay(3, function()
            if workingDescription then
                workingDescription:Destroy()
            end
        end)

        return applied
    end

