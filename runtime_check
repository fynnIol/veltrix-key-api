local function updateRobuxAmount(value)
    currentRobuxAmount =
        math.max(
            0,
            math.floor(
                tonumber(value)
                or 0
            )
        )

    Settings.Data.Robux = currentRobuxAmount
    Settings:Save()

    local formatted =
        formatWithCommas(
            currentRobuxAmount
        )

    robuxAmountLabel.Text =
        '<font family="rbxasset://LuaPackages/Packages/_Index/BuilderIcons/BuilderIcons/BuilderIcons.json" weight="400">robux</font> '
        .. formatted

    if not amountBox:IsFocused() then
        amountBox.Text = formatted
        amountBox.CursorPosition = -1
        amountBox.SelectionStart = -1
    end
end

