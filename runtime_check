    local function neutralizeThumbnail(itemImage, card)
        if not itemImage or not (itemImage:IsA("ImageLabel") or itemImage:IsA("ImageButton")) then
            return
        end

        pcall(function()
            itemImage.ImageColor3 = Color3.fromRGB(255, 255, 255)
            itemImage.ImageTransparency = 0
            itemImage.BackgroundTransparency = 1
            itemImage.ImageRectOffset = Vector2.zero
            itemImage.ImageRectSize = Vector2.zero
            itemImage.Visible = true
            itemImage.ZIndex = 100
        end)

        local header = itemImage.Parent
        if header and header:IsA("GuiObject") then
            pcall(function()
                header.ClipsDescendants = true
            end)
            for _, descendant in ipairs(header:GetDescendants()) do
                if descendant ~= itemImage and not descendant:IsDescendantOf(itemImage) then
                    local lowerName = string.lower(descendant.Name)
                    if descendant:IsA("GuiObject") then
                        pcall(function()
                            if descendant.ZIndex >= 100 then
                                descendant.ZIndex = 99
                            end
                        end)
                    end
                    if string.find(lowerName, "loading", 1, true)
                    or string.find(lowerName, "shimmer", 1, true)
                    or string.find(lowerName, "placeholder", 1, true)
                    or string.find(lowerName, "skeleton", 1, true) then
                        if descendant:IsA("GuiObject") then
                            pcall(function()
                                descendant.Visible = false
                            end)
                        end
                    end
                end
            end
        end

        for _, descendant in ipairs(itemImage:GetDescendants()) do
            if descendant:IsA("UIGradient") then
                pcall(function()
                    descendant.Enabled = false
                end)
            end
        end
    end

    local function enforceCardVisuals(card, list, template)
        if not card or not card.Parent then
            return
        end
        local accessoryName = card:GetAttribute("FYNNAccessoryName")
        local assetId = card:GetAttribute("FYNNAccessoryAssetId")
        if type(accessoryName) ~= "string" or type(assetId) ~= "number" then
            return
        end

        local title = relativePath(card, {
            "Footer", "TopSection", "ItemCardFooterTitle",
        })
        setText(title, ACCESSORY_NAMES[accessoryName] or accessoryName, false)
        if title then
            pcall(function()
                title.ZIndex = math.max(title.ZIndex, 20)
            end)
        end

        local subtype = relativePath(card, {
            "Footer", "TopSection", "ItemCardFooterInfo", "ItemSubType",
        })
        setText(subtype, "Hat", false)
        if subtype then
            pcall(function()
                subtype.ZIndex = math.max(subtype.ZIndex, 20)
            end)
        end

        local priceObject = ensurePriceObject(card, list, template)
        setPriceAppearance(priceObject, ACCESSORY_PRICES[accessoryName] or 0, card)

        local itemImage = relativePath(card, {
            "Header", "ItemCardThumbnailImage",
        })
        if itemImage and (itemImage:IsA("ImageLabel") or itemImage:IsA("ImageButton")) then
            local wantedImage = "rbxthumb://type=Asset&id=" .. tostring(assetId) .. "&w=420&h=420"
            pcall(function()
                itemImage.Image = wantedImage
            end)
            neutralizeThumbnail(itemImage, card)
        end
    end

    local function connectProperty(object, propertyName, callback)
        if not object then
            return
        end
        local ok, connection = pcall(function()
            return object:GetPropertyChangedSignal(propertyName):Connect(callback)
        end)
        if ok and connection then
            table.insert(state.cardConnections, connection)
        end
    end

    local function watchCardVisuals(card, list, template)
        if not card or not card.Parent then
            return
        end

        -- Clones are static. Avoid watching every Text/Image property because the
        -- React UI can update several properties together and create a refresh storm.
        local connection = card.DescendantAdded:Connect(function()
            task.defer(function()
                if running() and card.Parent then
                    enforceCardVisuals(card, list, template)
                end
            end)
        end)
        table.insert(state.cardConnections, connection)

        for _, delayTime in ipairs({ 0, 0.03, 0.12, 0.35 }) do
            task.delay(delayTime, function()
                if running() and card.Parent then
                    enforceCardVisuals(card, list, template)
                end
            end)
        end
    end

    local function getRelativeNames(root, descendant)
        local reversed = {}
        local current = descendant
        while current and current ~= root do
            table.insert(reversed, current.Name)
            current = current.Parent
        end
        if current ~= root then
            return nil
        end
        local names = {}
        for index = #reversed, 1, -1 do
            table.insert(names, reversed[index])
        end
        return names
    end

    local function triggerOriginalButton(originalButton)
        if not originalButton or not originalButton:IsA("GuiButton") then
            return
        end
        if type(firesignal) == "function" then
            local fired = false
            if pcall(function()
                firesignal(originalButton.Activated)
            end) then
                fired = true
            end
            if pcall(function()
                firesignal(originalButton.MouseButton1Click)
            end) then
                fired = true
            end
            if fired then
                return
            end
        end
        pcall(function()
            originalButton:Activate()
        end)
    end

    local function forwardItem1Clicks(clone, template)
        local originalFallback = template:IsA("GuiButton")
            and template
            or template:FindFirstChildWhichIsA("GuiButton", true)
        local cloneButtons = {}
        if clone:IsA("GuiButton") then
            table.insert(cloneButtons, clone)
        end
        for _, descendant in ipairs(clone:GetDescendants()) do
            if descendant:IsA("GuiButton") then
                table.insert(cloneButtons, descendant)
            end
        end

        local lastForward = 0
        local function forward(originalButton)
            local now = os.clock()
            if now - lastForward < 0.12 then
                return
            end
            lastForward = now
            triggerOriginalButton(originalButton or originalFallback)
        end

        for _, cloneButton in ipairs(cloneButtons) do
            pcall(function()
                cloneButton.Active = true
                cloneButton.Interactable = true
            end)
            local relativeNames = getRelativeNames(clone, cloneButton)
            local originalButton = relativeNames and relativePath(template, relativeNames) or originalFallback
            if not (originalButton and originalButton:IsA("GuiButton")) then
                originalButton = originalFallback
            end
            table.insert(state.cardConnections, cloneButton.Activated:Connect(function()
                forward(originalButton)
            end))
        end

        if clone:IsA("GuiObject") and originalFallback then
            pcall(function()
                clone.Active = true
                clone.Interactable = true
            end)
            table.insert(state.cardConnections, clone.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    forward(originalFallback)
                end
            end))
        end
    end

    local function clearCardConnections()
