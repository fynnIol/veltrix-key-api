local function refreshOverheadOptions()
    local selectedOption = overheadOptions[overheadSelection]
    local selectedOrder = selectedOption and selectedOption.LayoutOrder or 1

    for textValue, option in pairs(overheadOptions) do
        local selected = textValue == overheadSelection
        local rowIndex = option.LayoutOrder - 1

        if option.LayoutOrder > selectedOrder then
            rowIndex = rowIndex - 1
        end

        option.Visible = not selected
        option.Active = not selected
        option.Selectable = not selected
        option.Position = UDim2.fromOffset(0, math.max(0, rowIndex) * 38)
        option.Size = UDim2.fromOffset(160, 38)
        option.BackgroundColor3 = Color3.fromRGB(8, 8, 8)
        option.BackgroundTransparency = 1
        option.Text = textValue
        option.TextColor3 = COLORS.White
        option.TextTransparency = 0
        option.TextStrokeTransparency = 1
        option.ZIndex = 48

        local oldGradient = option:FindFirstChild("SelectedGradient")
        if oldGradient then
            oldGradient:Destroy()
        end

        local divider = option:FindFirstChild("Divider")

        if divider then
            divider.Visible = not selected and rowIndex > 0
            divider.ZIndex = 49
        end
    end
end

