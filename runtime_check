    local function clearCurrentCards(list)
        clearCardConnections()
        if not list then
            return
        end
        for _, child in ipairs(list:GetChildren()) do
            if child:GetAttribute("FYNNAccessoryInspectCard") then
                pcall(function()
                    child:Destroy()
                end)
            end
        end
    end

    local function equippedTotal()
        local total = 0
        for _, accessoryName in ipairs(state.equipped) do
            total += ACCESSORY_PRICES[accessoryName] or 0
        end
        return total
    end

    local function updateTotalPrice()
        local priceText = exactPath(totalPricePath)
        if not priceText or not (priceText:IsA("TextLabel") or priceText:IsA("TextButton") or priceText:IsA("TextBox")) then
            return
        end

        local info = state.totalLabels[priceText]
        local currentNumber = parseNumber(priceText.Text)
        if not info then
            info = {
                base = currentNumber,
                rendered = nil,
                writing = false,
            }
            state.totalLabels[priceText] = info
        elseif not info.writing and info.rendered ~= nil and currentNumber ~= info.rendered then
            -- Roblox loaded or changed its own total. Treat that as the new base,
            -- then add the FYNN-equipped limited total once.
            info.base = currentNumber
        end

        local wantedNumber = math.max(0, (info.base or 0) + equippedTotal())
        local wantedText = formatNumber(wantedNumber)
        info.writing = true
        pcall(function()
            if priceText.Text ~= wantedText then
                priceText.Text = wantedText
            end
            priceText.TextTransparency = 0
            priceText.Visible = true
        end)
        info.rendered = wantedNumber
        info.writing = false
    end

    local function rebuildAccessoryCards(force)
        if not running() then
            return
        end
        local list = exactPath(inspectListPath)
        if not list then
            state.lastList = nil
            state.lastSignature = nil
            return
        end
        local template = list:FindFirstChild("Item1")
        if not template then
            return
        end

        local signature = table.concat(state.equipped, "|") .. "#" .. tostring(state.rebuildVersion)
        if not force and state.lastList == list and state.lastSignature == signature then
            return
        end

        clearCurrentCards(list)
        local equippedCount = #state.equipped
        for index, accessoryName in ipairs(state.equipped) do
            local assetId = ACCESSORY_IDS[accessoryName]
            if assetId then
                local clone = template:Clone()
                clone.Name = "Item0_FYNN_" .. string.format("%02d", index)
                clone:SetAttribute("FYNNAccessoryInspectCard", true)
                clone:SetAttribute("FYNNAccessoryName", accessoryName)
                clone:SetAttribute("FYNNAccessoryAssetId", assetId)
                if clone:IsA("GuiObject") then
                    clone.LayoutOrder = -equippedCount + index - 1
                    clone.Visible = true
                end
                clone.Parent = list

                enforceCardVisuals(clone, list, template)
                forwardItem1Clicks(clone, template)

                watchCardVisuals(clone, list, template)
            end
        end

        state.lastList = list
        state.lastSignature = signature
        updateTotalPrice()
    end

    local function enforceExistingCards()
        local list = exactPath(inspectListPath)
        if not list then
            return
        end
        local template = list:FindFirstChild("Item1")
        for _, child in ipairs(list:GetChildren()) do
            if child:GetAttribute("FYNNAccessoryInspectCard") then
                enforceCardVisuals(child, list, template)
            end
        end
    end

    local function queueSync()
        if state.syncQueued or not running() then
            return
        end
        state.syncQueued = true
        task.defer(function()
            state.syncQueued = false
            rebuildAccessoryCards(false)
            updateTotalPrice()
        end)
    end

    env.__FYNN_SET_INSPECT_ACCESSORIES = function(accessoryList)
        if not running() then
            return
        end
        local wanted = {}
        local seen = {}
        local incoming = type(accessoryList) == "table" and accessoryList or {}
        for _, orderedName in ipairs(ACCESSORY_ORDER) do
            for _, incomingName in ipairs(incoming) do
                if incomingName == orderedName and not seen[orderedName] then
                    seen[orderedName] = true
                    table.insert(wanted, orderedName)
                    break
                end
            end
        end
        state.equipped = wanted
        state.rebuildVersion += 1
        state.lastSignature = nil
        queueSync()
    end

    local function watchTotalLabel(priceText)
        if not priceText
        or state.watchedTotalLabels[priceText]
        or not (priceText:IsA("TextLabel") or priceText:IsA("TextButton") or priceText:IsA("TextBox")) then
            return
        end
        state.watchedTotalLabels[priceText] = true
        local connection = priceText:GetPropertyChangedSignal("Text"):Connect(function()
            local info = state.totalLabels[priceText]
            if info and info.writing then
                return
            end
            task.defer(function()
                if running() and priceText.Parent then
                    updateTotalPrice()
                end
            end)
        end)
        table.insert(state.connections, connection)
    end

    local function refreshEverything(forceCards)
        if not running() then
            return
        end
        applyThumbnails()
        rebuildAccessoryCards(forceCards == true)
        local totalLabel = exactPath(totalPricePath)
        if totalLabel then
            watchTotalLabel(totalLabel)
        end
        updateTotalPrice()
    end

    local function queueRefresh(forceCards, delayTime)
        if not running() then
            return
        end
        if forceCards then
            state.lastSignature = nil
        end
        if state.refreshQueued then
            return
        end
        state.refreshQueued = true
        task.delay(delayTime or 0, function()
            state.refreshQueued = false
            refreshEverything(forceCards)
        end)
    end

    -- Prices are local constants and render immediately. Thumbnail requests are
    -- assigned directly without a blocking preload pass.

    refreshEverything(true)

    table.insert(state.connections, CoreGui.DescendantAdded:Connect(function(descendant)
        if not running() then
            return
        end
        local name = descendant.Name
        if name == "AvatarThumbnail"
        or name == "InspectAndBuy"
        or name == "Item1"
        or name == "List"
        or name == "PriceText"
        or name == "ItemCardPriceLineAmount" then
            queueRefresh(name == "InspectAndBuy" or name == "Item1" or name == "List", 0)
            queueRefresh(false, 0.12)
        end
    end))

    -- Slow safety pass only. No RenderStepped connection, no full hierarchy walk
    -- every frame, and no repeated image preloading.
    task.spawn(function()
        while running() do
            task.wait(0.5)
            refreshEverything(false)
        end
    end)
end)

