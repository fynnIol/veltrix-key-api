local function formatWithCommas(value)
    local digits =
        tostring(
            math.max(
                0,
                math.floor(
                    tonumber(value)
                    or 0
                )
            )
        )

    local formatted = digits

    while true do
        local nextValue, changes =
            formatted:gsub(
                "^(-?%d+)(%d%d%d)",
                "%1,%2"
            )

        formatted = nextValue

        if changes == 0 then
            break
        end
    end

    return formatted
end

