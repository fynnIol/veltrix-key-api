            removeVeltrixAccessory(player.Character, avatarSelection)
            equippedAvatarAccessories[avatarSelection] = nil
            success = true
        else
            success = equipAccessory(player.Character, avatarSelection)
            if success then
                equippedAvatarAccessories[avatarSelection] = true
            end
        end

        saveEquippedAvatarAccessories()
        refreshAvatarOptions()

        setButtonStatus(
            equipButton,
            success
                and (wasEquipped and "UNEQUIPPED" or "EQUIPPED")
                or "FAILED",
            equippedAvatarAccessories[avatarSelection]
                and "UNEQUIP"
                or "EQUIP"
        )
    end)

