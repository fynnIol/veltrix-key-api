local function applyProgressGradient(
    progress,
    filledColor,
    emptyColor
)
    local value =
        math.clamp(progress, 0, 1)

    local leftEdge =
        math.max(
            0,
            value - 0.0005
        )

    local rightEdge =
        math.min(
            1,
            value + 0.0005
        )

    actionGradient.Color =
        ColorSequence.new({
            ColorSequenceKeypoint.new(
                0,
                filledColor
            ),
            ColorSequenceKeypoint.new(
                leftEdge,
                filledColor
            ),
            ColorSequenceKeypoint.new(
                rightEdge,
                emptyColor
            ),
            ColorSequenceKeypoint.new(
                1,
                emptyColor
            ),
        })
end

