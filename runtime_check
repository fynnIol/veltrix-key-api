            return source
        end
        if list then
            for _, descendant in ipairs(list:GetDescendants()) do
                if descendant.Name == "ItemCardPriceLineAmount"
                and not descendant:IsDescendantOf(preferredTemplate or list.Parent)
                and (descendant:IsA("TextLabel") or descendant:IsA("TextButton") or descendant:IsA("TextBox")) then
                    return descendant
