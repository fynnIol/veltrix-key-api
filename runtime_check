-- Gift Sent Notification

local notificationSystem = nil
local notificationLoadAttempted = false
local selectedGiftUsername = ""

local function getNotificationSystem()
    if notificationLoadAttempted then
        return notificationSystem
    end

    notificationLoadAttempted = true

    local moduleScript =
        ReplicatedStorage:FindFirstChild(
            "NotificationSystem"
        )

    if not moduleScript
    or not moduleScript:IsA("ModuleScript") then
        warn(
            "[Veltrix] ReplicatedStorage.NotificationSystem was not found."
        )

        return nil
    end

    local ok, result = pcall(
        require,
        moduleScript
    )

    if ok and type(result) == "table" then
        notificationSystem = result
        return notificationSystem
    end

    warn(
        "[Veltrix] Failed to require NotificationSystem:",
        result
    )

    return nil
end

local function getGiftModalCloseButton()
    local playerGui = player:FindFirstChild("PlayerGui")
    local speedGameUI =
        playerGui
        and playerGui:FindFirstChild("SpeedGameUI")
    local modals =
        speedGameUI
        and speedGameUI:FindFirstChild("Modals")
    local giftModal =
        modals
        and modals:FindFirstChild("GiftToPlayerModal")
    local header =
        giftModal
        and giftModal:FindFirstChild("Header")

    return header
        and header:FindFirstChild("CloseButton")
end

local function pressGuiButton(button)
    if not button or not button:IsA("GuiButton") then
        return false
    end

    if typeof(firesignal) == "function" then
        local fired = false

        local activatedOk = pcall(function()
            firesignal(button.Activated)
        end)

        if activatedOk then
            fired = true
        end

        local clickOk = pcall(function()
            firesignal(button.MouseButton1Click)
        end)

        if clickOk then
            fired = true
        end

        if fired then
            return true
        end
    end

    local ok = pcall(function()
        button:Activate()
    end)

    return ok
end

local function playBuySound()
    local gameSounds =
        SoundService:FindFirstChild("GameSounds")
    local buySound =
        gameSounds
        and gameSounds:FindFirstChild("BUY")

    if buySound and buySound:IsA("Sound") then
        pcall(function()
            buySound:Play()
        end)
    end
end

local function finishGiftNotificationEffects()
    playBuySound()

    task.defer(function()
        pressGuiButton(
            getGiftModalCloseButton()
        )
    end)
end

local function showGiftSentNotification(username)
    local cleanUsername = trimText(username)

    if cleanUsername == "" then
        return false
    end

    local system = getNotificationSystem()

    if not system then
        return false
    end

    local message =
        "Gift sent to "
        .. cleanUsername
        .. "!"

    local successColor =
        Color3.fromRGB(80, 255, 120)

    if type(system.ShowGeneralNotification)
        == "function" then
        local ok, errorMessage = pcall(
            function()
                system:ShowGeneralNotification(
                    message,
                    successColor,
                    4
                )
            end
        )

        if ok then
            finishGiftNotificationEffects()
            return true
        end

        warn(
            "[Veltrix] ShowGeneralNotification failed:",
            errorMessage
        )
    end

    if type(system.ShowMessage) == "function" then
        local ok, errorMessage = pcall(
            function()
                system:ShowMessage(
                    message,
                    successColor
                )
            end
        )

        if ok then
            finishGiftNotificationEffects()
            return true
        end

        warn(
            "[Veltrix] ShowMessage failed:",
            errorMessage
        )
    end

    warn(
        "[Veltrix] NotificationSystem has no usable notification method."
    )

    return false
end

