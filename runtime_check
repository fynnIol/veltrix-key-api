local function startFakeBehavior(
    model,
    humanoid
)
    local followAngle = fakeRandom:NextNumber(0, math.pi * 2)
    local followDistance = fakeRandom:NextNumber(3.5, 8)
    local wanderer = fakeRandom:NextNumber() <= 0.58

    local function moveFakeTo(target)
        if typeof(target) ~= "Vector3" then
            return
        end

        model:SetAttribute("VeltrixMoveTarget", target)
        model:SetAttribute("VeltrixMoveCommandAt", os.clock())
        humanoid:MoveTo(target)
    end

    task.spawn(function()
        local followAnchor = nil
        local lastPlayerMovementAt = os.clock()
        local nextWanderAt = os.clock() + fakeRandom:NextNumber(2.5, 6)
        local followQueued = false
        local ignoreFollowUntil = 0

        task.wait(fakeRandom:NextNumber(0.15, 0.65))

        while model.Parent and screenGui.Parent do
            local playerRoot = player.Character
                and player.Character:FindFirstChild("HumanoidRootPart")
            local fakeRoot = model:FindFirstChild("HumanoidRootPart")

            if not playerRoot or not fakeRoot then
                task.wait(0.2)
                continue
            end

            local now = os.clock()
            local currentPlayerPosition = playerRoot.Position

            if not followAnchor then
                followAnchor = currentPlayerPosition
            end

            local movedDistance = Vector3.new(
                currentPlayerPosition.X - followAnchor.X,
                0,
                currentPlayerPosition.Z - followAnchor.Z
            ).Magnitude

            if movedDistance >= 1.5 then
                lastPlayerMovementAt = now
                nextWanderAt = now + fakeRandom:NextNumber(2.5, 5.5)

                if not followQueued and now >= ignoreFollowUntil then
                    followAnchor = currentPlayerPosition

                    if fakeRandom:NextNumber() <= 0.10 then
                        ignoreFollowUntil = now + fakeRandom:NextNumber(2.2, 5)
                        humanoid:Move(Vector3.zero, false)
                    else
                        followQueued = true

                        task.spawn(function()
                            task.wait(fakeRandom:NextNumber(0.5, 2))

                            if not model.Parent or not screenGui.Parent then
                                followQueued = false
                                return
                            end

                            local latestPlayerRoot = player.Character
                                and player.Character:FindFirstChild("HumanoidRootPart")
                            local latestFakeRoot = model:FindFirstChild("HumanoidRootPart")

                            if latestPlayerRoot and latestFakeRoot then
                                local angle = followAngle
                                    + fakeRandom:NextNumber(-0.35, 0.35)
                                local distance = math.max(
                                    2.5,
                                    followDistance
                                        + fakeRandom:NextNumber(-1, 1)
                                )
                                local target = latestPlayerRoot.Position
                                    + Vector3.new(
                                        math.cos(angle) * distance,
                                        0,
                                        math.sin(angle) * distance
                                    )

                                local savedSpeed = model:GetAttribute(
                                    "VeltrixWalkSpeed"
                                )

                                if typeof(savedSpeed) == "number" then
                                    humanoid.WalkSpeed = savedSpeed
                                end

                                moveFakeTo(target)
                            end

                            task.wait(fakeRandom:NextNumber(0.15, 0.4))
                            followQueued = false
                        end)
                    end
                end
            elseif wanderer
            and not followQueued
            and now - lastPlayerMovementAt >= 1.4
            and now >= nextWanderAt then
                local target

                if fakeRandom:NextNumber() <= 0.35 then
                    local away = Vector3.new(
                        fakeRoot.Position.X - playerRoot.Position.X,
                        0,
                        fakeRoot.Position.Z - playerRoot.Position.Z
                    )

                    if away.Magnitude < 0.1 then
                        local angle = fakeRandom:NextNumber(0, math.pi * 2)
                        away = Vector3.new(math.cos(angle), 0, math.sin(angle))
                    else
                        away = away.Unit
                    end

                    target = fakeRoot.Position
                        + away * fakeRandom:NextNumber(10, 24)
                        + Vector3.new(
                            fakeRandom:NextNumber(-5, 5),
                            0,
                            fakeRandom:NextNumber(-5, 5)
                        )
                else
                    local angle = fakeRandom:NextNumber(0, math.pi * 2)
                    local distance = fakeRandom:NextNumber(6, 18)
                    target = fakeRoot.Position
                        + Vector3.new(
                            math.cos(angle) * distance,
                            0,
                            math.sin(angle) * distance
                        )
                end

                moveFakeTo(target)
                nextWanderAt = now + fakeRandom:NextNumber(3.5, 8)
            end

            task.wait(0.12)
        end
    end)

    -- Pair every NPC body part with every local-character body part.
    -- This includes both HumanoidRootParts and guarantees zero physical push.
    task.spawn(function()
        local constraintFolder = Instance.new("Folder")
        constraintFolder.Name = "VeltrixPlayerNoCollision"
        constraintFolder.Parent = model

        local currentCharacter = nil
        local characterAddedConnection = nil
        local modelAddedConnection = nil
        local paired = {}

        local function pairParts(npcPart, playerPart)
            if not npcPart:IsA("BasePart")
            or not playerPart:IsA("BasePart")
            or not npcPart.Parent
            or not playerPart.Parent then
                return
            end

            local partPairs = paired[npcPart]

            if not partPairs then
                partPairs = setmetatable({}, { __mode = "k" })
                paired[npcPart] = partPairs
            end

            if partPairs[playerPart] then
                return
            end

            local constraint = Instance.new("NoCollisionConstraint")
            constraint.Part0 = npcPart
            constraint.Part1 = playerPart
            constraint.Parent = constraintFolder
            partPairs[playerPart] = constraint
        end

        local function pairNpcPart(npcPart)
            if not currentCharacter or not npcPart:IsA("BasePart") then
                return
            end

            for _, playerPart in ipairs(currentCharacter:GetDescendants()) do
                if playerPart:IsA("BasePart") then
                    pairParts(npcPart, playerPart)
                end
            end
        end

        local function pairPlayerPart(playerPart)
            if not playerPart:IsA("BasePart") then
                return
            end

            for _, npcPart in ipairs(model:GetDescendants()) do
                if npcPart:IsA("BasePart") then
                    pairParts(npcPart, playerPart)
                end
            end
        end

        local function rebuildForCharacter(character)
            currentCharacter = character
            paired = {}
            constraintFolder:ClearAllChildren()

            if characterAddedConnection then
                characterAddedConnection:Disconnect()
                characterAddedConnection = nil
            end

            if not currentCharacter then
                return
            end

            for _, npcPart in ipairs(model:GetDescendants()) do
                if npcPart:IsA("BasePart") then
                    pairNpcPart(npcPart)
                end
            end

            characterAddedConnection = currentCharacter.DescendantAdded:Connect(
                pairPlayerPart
            )
        end

        modelAddedConnection = model.DescendantAdded:Connect(function(instance)
            if instance:IsA("BasePart") then
                pairNpcPart(instance)
            end
        end)

        rebuildForCharacter(player.Character)

        while model.Parent and screenGui.Parent do
            if player.Character ~= currentCharacter then
                rebuildForCharacter(player.Character)
            end

            task.wait(0.35)
        end

        if characterAddedConnection then
            characterAddedConnection:Disconnect()
        end

        if modelAddedConnection then
            modelAddedConnection:Disconnect()
        end
    end)

    -- Reset an NPC to SpawnLocation after five seconds of trying to move
    -- without making meaningful progress. Intentional standing is ignored.
    task.spawn(function()
        local root = model:FindFirstChild("HumanoidRootPart")
        local lastPosition = root and root.Position or nil
        local lastProgressAt = os.clock()

        task.wait(0.5)

        while model.Parent and screenGui.Parent do
            root = model:FindFirstChild("HumanoidRootPart")

            if root then
                local now = os.clock()
                local position = root.Position
                local target = model:GetAttribute("VeltrixMoveTarget")
                local moved = lastPosition and Vector3.new(
                    position.X - lastPosition.X,
                    0,
                    position.Z - lastPosition.Z
                ).Magnitude or 0

                if moved >= 1.1 then
                    lastPosition = position
                    lastProgressAt = now
                end

                local tryingToMove = typeof(target) == "Vector3"
                    and Vector3.new(
                        target.X - position.X,
                        0,
                        target.Z - position.Z
                    ).Magnitude > 2.5

                if typeof(target) == "Vector3" and not tryingToMove then
                    model:SetAttribute("VeltrixMoveTarget", nil)
                    lastPosition = position
                    lastProgressAt = now
                elseif tryingToMove and now - lastProgressAt >= 5 then
                    humanoid:Move(Vector3.zero, false)
                    model:SetAttribute("VeltrixMoveTarget", nil)
                    model:PivotTo(getSpawnCFrame())

                    local resetRoot = model:FindFirstChild("HumanoidRootPart")

                    if resetRoot then
                        resetRoot.AssemblyLinearVelocity = Vector3.zero
                        resetRoot.AssemblyAngularVelocity = Vector3.zero
                        lastPosition = resetRoot.Position
                    else
                        lastPosition = nil
                    end

                    humanoid.Sit = false
                    humanoid.PlatformStand = false
                    humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                    lastProgressAt = now
                elseif not tryingToMove then
                    lastPosition = position
                    lastProgressAt = now
                end
            end

            task.wait(0.5)
        end
    end)

    -- Keep fake players in their own collision group.
    task.spawn(function()
        local fakeGroup = screenGui:GetAttribute(
            "FakeCollisionGroup"
        ) or "FynnFakePlayers"

        while model.Parent and screenGui.Parent do
            for _, descendant in ipairs(model:GetDescendants()) do
                if descendant:IsA("BasePart") then
                    pcall(function()
                        descendant.CollisionGroup = fakeGroup
                    end)

                    descendant.CanTouch = false
                    descendant.CanQuery = false
                end
            end

            task.wait(0.35)
        end
    end)

    task.spawn(function()
        task.wait(2)

        while model.Parent and screenGui.Parent do
            task.wait(2)

            if fakeRandom:NextNumber() <= 0.02
            and humanoid.FloorMaterial ~= Enum.Material.Air then
                humanoid.Jump = true
            end
        end
    end)

    task.spawn(function()
        local activeTalker = fakeRandom:NextNumber() <= 0.25
        local chatInterval = activeTalker and 2 or 4
        local chatChance = activeTalker and 0.02 or 0.005

        model:SetAttribute("VeltrixNormalTalker", activeTalker)
        task.wait(fakeRandom:NextNumber(1, 5))

        while model.Parent and screenGui.Parent do
            task.wait(chatInterval)

            if fakeRandom:NextNumber() <= chatChance
            and not queuedChatModels[model]
            and #chatQueue < 12 then
                queuedChatModels[model] = true

                table.insert(chatQueue, {
                    Model = model,
                    Message = getFakeChatMessage(),
                })
            end
        end
    end)
end

local function spawnFakePlayer()
    if getFakePlayerCount() + pendingFakeSpawns
        >= FAKE_PLAYER_LIMIT then
        refreshFakeCount()
        return false
    end

    local username = chooseFakeUsername()

    if not username then
        return false
    end

    pendingFakeSpawns += 1
    pendingFakeUsernames[username] = true
    refreshFakeCount()

    local function finishPending()
        pendingFakeSpawns = math.max(
            0,
            pendingFakeSpawns - 1
        )
        pendingFakeUsernames[username] = nil
        refreshFakeCount()
    end

    local userId = getUserId(username)

    if not userId or not screenGui.Parent then
        finishPending()
        return false
    end

    local description = nil

    pcall(function()
        description =
            Players:GetHumanoidDescriptionFromUserId(userId)
    end)

    local ok, model = pcall(function()
        if description then
            return Players:CreateHumanoidModelFromDescription(
                description,
                Enum.HumanoidRigType.R15
            )
        end

        return Players:CreateHumanoidModelFromUserId(userId)
    end)

    if not ok or not model then
        ok, model = pcall(function()
            return Players:CreateHumanoidModelFromUserId(userId)
        end)
    end

    if not ok
    or not model
    or not model:IsA("Model")
    or not screenGui.Parent then
        if model and typeof(model) == "Instance" then
            model:Destroy()
        end

        finishPending()
        return false
    end

    if getFakePlayerCount() + pendingFakeSpawns - 1
        >= FAKE_PLAYER_LIMIT then
        model:Destroy()
        finishPending()
        return false
    end

    local humanoid = model:FindFirstChildOfClass("Humanoid")
    local root = model:FindFirstChild("HumanoidRootPart")

    if not humanoid or not root then
        model:Destroy()
        finishPending()
        return false
    end

    local displayName = getDisplayName(userId, username)

    model.Name = displayName
    model:SetAttribute("VeltrixUsername", username)
    model:SetAttribute("VeltrixDisplayName", displayName)

    humanoid.DisplayName = displayName
    humanoid.NameDisplayDistance = 100
    humanoid.HealthDisplayDistance = 0
    humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.Subject
    humanoid.NameOcclusion = Enum.NameOcclusion.NoOcclusion

    local walkSpeed = fakeRandom:NextInteger(100, 400)

    model:SetAttribute("VeltrixWalkSpeed", walkSpeed)
    humanoid.WalkSpeed = walkSpeed
    humanoid.AutoRotate = true

    local fakeCollisionGroup = screenGui:GetAttribute(
        "FakeCollisionGroup"
    ) or "FynnFakePlayers"

    local function applyFakeCollision(instance)
        if not instance:IsA("BasePart") then
            return
        end

        pcall(function()
            instance.CollisionGroup = fakeCollisionGroup
        end)

        instance.CanTouch = false
        instance.CanQuery = false
    end

    for _, descendant in ipairs(model:GetDescendants()) do
        applyFakeCollision(descendant)
    end

    model.DescendantAdded:Connect(applyFakeCollision)

    model.Parent = fakePlayersFolder
    model:PivotTo(getSpawnCFrame())

    activeFakeUsernames[username] = true
    table.insert(fakePlayers, model)

    setupFakeAnimations(model, humanoid, description)
    startFakeBehavior(model, humanoid)

    model.Destroying:Connect(function()
        activeFakeUsernames[username] = nil
        queuedChatModels[model] = nil
        refreshFakeCount()
    end)

    finishPending()
    refreshFakeCount()

    return true
end

local function deleteRandomFakePlayer()
    cleanFakePlayers()

    if #fakePlayers == 0 then
        refreshFakeCount()
        return
    end

    local index = fakeRandom:NextInteger(1, #fakePlayers)
    local model = table.remove(fakePlayers, index)

    if model then
        local username = model:GetAttribute("VeltrixUsername")

        if username then
            activeFakeUsernames[username] = nil
        end

        queuedChatModels[model] = nil
        model:Destroy()
    end

    refreshFakeCount()
end

