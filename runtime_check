    applyDescriptionPreservingAccessories = function(character, description)
        if avatarApplyingDescription
        or not character
        or not description then
            return false
        end

        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then
            return false
        end

        avatarApplyingDescription = true

        -- Do not preserve the player's old hats, hair, or other catalog
        -- accessories. The target avatar supplies its own appearance, and
        -- finishAvatarEffects() restores only accessories selected in FYNN.
        cleanCharacterAppearance(character)
        local applied = applyDescriptionCompat(humanoid, description)

        if not applied then
            avatarApplyingDescription = false
            return false
        end

        task.wait(0.2)
        pcall(function()
            humanoid:BuildRigFromAttachments()
        end)

        avatarApplyingDescription = false
        return true
    end

    local function copyCharacterLocalObjects(oldCharacter, newCharacter)
        if not oldCharacter or not newCharacter then
            return
        end

        for _, child in ipairs(oldCharacter:GetChildren()) do
            local shouldCopy = child:IsA("LocalScript")
                or child:IsA("ModuleScript")
                or child:IsA("ValueBase")

            if shouldCopy and not newCharacter:FindFirstChild(child.Name) then
                local oldArchivable = child.Archivable
                child.Archivable = true

                pcall(function()
                    child:Clone().Parent = newCharacter
                end)

                child.Archivable = oldArchivable
            end
        end
    end

    local function replaceLocalCharacter(newCharacter)
        if not newCharacter then
            return false
        end

        local oldCharacter = player.Character
        local oldHumanoid = oldCharacter
            and oldCharacter:FindFirstChildOfClass("Humanoid")
        local oldRoot = oldCharacter
            and oldCharacter:FindFirstChild("HumanoidRootPart")
        local oldPivot = oldRoot and oldRoot.CFrame or CFrame.new(0, 8, 0)

        local newHumanoid = newCharacter:FindFirstChildOfClass("Humanoid")
        local newRoot = newCharacter:FindFirstChild("HumanoidRootPart")

        if not newHumanoid or not newRoot then
            newCharacter:Destroy()
            return false
        end

        copyCharacterLocalObjects(oldCharacter, newCharacter)

        if oldHumanoid then
            newHumanoid.WalkSpeed = oldHumanoid.WalkSpeed
            newHumanoid.AutoRotate = oldHumanoid.AutoRotate

            pcall(function()
                newHumanoid.UseJumpPower = oldHumanoid.UseJumpPower
                newHumanoid.JumpPower = oldHumanoid.JumpPower
                newHumanoid.JumpHeight = oldHumanoid.JumpHeight
            end)

            local healthRatio = oldHumanoid.MaxHealth > 0
                and oldHumanoid.Health / oldHumanoid.MaxHealth
                or 1
            newHumanoid.Health = math.clamp(
                healthRatio * newHumanoid.MaxHealth,
                1,
                newHumanoid.MaxHealth
            )
        end

        newCharacter.Name = player.Name
        newCharacter.Parent = workspace
        newCharacter:PivotTo(oldPivot)

        avatarApplyingDescription = true
        local assigned = pcall(function()
            player.Character = newCharacter
        end)
        avatarApplyingDescription = false

        if not assigned then
            newCharacter:Destroy()
            return false
        end

        local camera = workspace.CurrentCamera
        if camera then
            camera.CameraSubject = newHumanoid
        end

        if oldCharacter and oldCharacter ~= newCharacter then
            task.defer(function()
                pcall(function()
                    oldCharacter:Destroy()
                end)
            end)
        end

        return true
    end

    local function applySourceModelAppearance(character, description)
        if not character or not description then
            return false
        end

        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then
            return false
        end

        local sourceModel = createModelFromDescription(
            description,
            Enum.HumanoidRigType.R15
        )
        if not sourceModel then
            return false
        end

        local sourceHumanoid = sourceModel:FindFirstChildOfClass("Humanoid")
        if not sourceHumanoid then
            sourceModel:Destroy()
            return false
        end

        if humanoid.RigType ~= Enum.HumanoidRigType.R15 then
            return replaceLocalCharacter(sourceModel)
        end

        local bodyParts = {
            { "Head", Enum.BodyPartR15.Head },
            { "UpperTorso", Enum.BodyPartR15.UpperTorso },
            { "LowerTorso", Enum.BodyPartR15.LowerTorso },
            { "LeftUpperArm", Enum.BodyPartR15.LeftUpperArm },
            { "LeftLowerArm", Enum.BodyPartR15.LeftLowerArm },
            { "LeftHand", Enum.BodyPartR15.LeftHand },
            { "RightUpperArm", Enum.BodyPartR15.RightUpperArm },
            { "RightLowerArm", Enum.BodyPartR15.RightLowerArm },
            { "RightHand", Enum.BodyPartR15.RightHand },
            { "LeftUpperLeg", Enum.BodyPartR15.LeftUpperLeg },
            { "LeftLowerLeg", Enum.BodyPartR15.LeftLowerLeg },
            { "LeftFoot", Enum.BodyPartR15.LeftFoot },
            { "RightUpperLeg", Enum.BodyPartR15.RightUpperLeg },
            { "RightLowerLeg", Enum.BodyPartR15.RightLowerLeg },
            { "RightFoot", Enum.BodyPartR15.RightFoot },
        }

        local replacedAny = false

        for _, bodyPartInfo in ipairs(bodyParts) do
            local sourcePart = sourceModel:FindFirstChild(bodyPartInfo[1])

            if sourcePart and sourcePart:IsA("BasePart") then
                local replacement = sourcePart:Clone()
                replacement.Name = bodyPartInfo[1]

                local replaced = pcall(function()
                    humanoid:ReplaceBodyPartR15(
                        bodyPartInfo[2],
                        replacement
                    )
                end)

                if replaced then
                    replacedAny = true
                else
                    replacement:Destroy()
                end
            end
        end

        for _, className in ipairs({
            "BodyColors",
            "Shirt",
            "Pants",
            "ShirtGraphic",
        }) do
            for _, existing in ipairs(character:GetChildren()) do
                if existing.ClassName == className then
                    existing:Destroy()
                end
            end

            local sourceAppearance = sourceModel:FindFirstChildOfClass(
                className
            )
            if sourceAppearance then
                sourceAppearance:Clone().Parent = character
            end
        end

        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Accessory")
            and child:GetAttribute("VeltrixAvatarAccessory") ~= true then
                child:Destroy()
            end
        end

        for _, sourceAccessory in ipairs(sourceModel:GetChildren()) do
            if sourceAccessory:IsA("Accessory") then
                local clone = sourceAccessory:Clone()
                stripAccessoryJoints(clone)

                local added = pcall(function()
                    humanoid:AddAccessory(clone)
                end)

                if not added then
                    clone:Destroy()
                end
            end
        end

        for _, sourceScale in ipairs(sourceHumanoid:GetChildren()) do
            if sourceScale:IsA("NumberValue")
            and sourceScale.Name:match("Scale$") then
                local targetScale = humanoid:FindFirstChild(sourceScale.Name)
                if targetScale and targetScale:IsA("NumberValue") then
                    targetScale.Value = sourceScale.Value
                end
            end
        end

        -- The source avatar's own accessories stay, while old player
        -- accessories are discarded. FYNN-selected accessories are applied
        -- afterward by finishAvatarEffects().
        pcall(function()
            humanoid:BuildRigFromAttachments()
        end)

        sourceModel:Destroy()
        return replacedAny
    end

    local function replaceRightLegFromDescription(character, description)
        if not character or not description then
            return false
        end

        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid
        or humanoid.RigType ~= Enum.HumanoidRigType.R15 then
            return false
        end

        local sourceModel = createModelFromDescription(
            description,
            Enum.HumanoidRigType.R15
        )
        if not sourceModel then
            return false
        end

        local legParts = {
            { "RightUpperLeg", Enum.BodyPartR15.RightUpperLeg },
            { "RightLowerLeg", Enum.BodyPartR15.RightLowerLeg },
            { "RightFoot", Enum.BodyPartR15.RightFoot },
        }
        local replacedAny = false

        for _, legInfo in ipairs(legParts) do
            local sourcePart = sourceModel:FindFirstChild(legInfo[1])

            if sourcePart and sourcePart:IsA("BasePart") then
                local replacement = sourcePart:Clone()
                replacement.Name = legInfo[1]

                local replaced = pcall(function()
                    humanoid:ReplaceBodyPartR15(
                        legInfo[2],
                        replacement
                    )
                end)

                if replaced then
                    replacedAny = true
                else
                    replacement:Destroy()
                end
            end
        end

        pcall(function()
            humanoid:BuildRigFromAttachments()
        end)

        sourceModel:Destroy()
        return replacedAny
    end

    local function finishAvatarEffects(character)
        if not character or player.Character ~= character then
            return
        end

        for _, child in ipairs(character:GetChildren()) do
            if child:GetAttribute("VeltrixAvatarAccessory") == true then
                local accessoryName = child:GetAttribute(
                    "VeltrixAvatarAccessoryName"
                )

                if not equippedAvatarAccessories[accessoryName] then
                    child:Destroy()
                end
            end
        end

        for _, accessoryName in ipairs(ACCESSORY_ORDER) do
            if equippedAvatarAccessories[accessoryName] then
                equipAccessory(character, accessoryName)
            end
        end

        -- Description application can restore the head, so apply the
        -- local Headless effect after the avatar/accessory pass.
        if not avatarHasNativeHeadless then
            setHeadless(character, headlessEnabled)
        end

        refreshNativeToggleLocks()
        applyOverhead()
    end

    local function buildAvatarDescription(userId, useKorblox)
        local description = getCachedUserDescription(userId)
        if not description then
            return nil
        end

        updateNativeAvatarLocksFromDescription(description)
        baseRightLegId = description.RightLeg

        if useKorblox and not avatarHasNativeKorblox then
            description.RightLeg = KORBLOX_RIGHT_LEG_ID
        end

        return description
    end

    local function applyUserAvatar(character, userId)
        if avatarApplyingDescription
        or not character
        or not userId
        or userId <= 0 then
            return false
        end

        local description = buildAvatarDescription(
            userId,
            korbloxEnabled
        )
        if not description then
            return false
        end

        local applied = applyDescriptionPreservingAccessories(
            character,
            description
        )

        -- A replicated player character can reject client-side
        -- ApplyDescription calls. ReplaceBodyPartR15 uses a locally-created
        -- source rig and gives the client a reliable visual fallback.
        local transferred = applySourceModelAppearance(
            character,
            description
        )
        description:Destroy()

        applied = applied or transferred

        if applied then
            finishAvatarEffects(player.Character or character)
        end

        return applied
    end

    local function applyKorblox(character, enabled)
        if avatarApplyingDescription
        or not character
        or avatarHasNativeKorblox then
            return false
        end

        local sourceUserId = targetAvatarUserId > 0
            and targetAvatarUserId
            or player.UserId
        local description = buildAvatarDescription(
            sourceUserId,
            enabled
        )

        if not description then
            return false
        end

        if enabled and not avatarHasNativeKorblox then
            description.RightLeg = KORBLOX_RIGHT_LEG_ID
        elseif not enabled then
            description.RightLeg = getOwnBaseRightLegId()
                or description.RightLeg
        end

        local applied = applyDescriptionPreservingAccessories(
            character,
            description
        )

        -- ReplaceBodyPartR15 is the runtime-safe method for changing an R15
        -- MeshPart body package when MeshId itself cannot be edited.
        local replaced = replaceRightLegFromDescription(
            player.Character or character,
            description
        )
        description:Destroy()

        applied = applied or replaced

        if applied then
            finishAvatarEffects(player.Character or character)
        end

        return applied
    end

    local function resolveAvatarUser(text)
        local cleaned = tostring(text or "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")
            :gsub("^@", "")

        if cleaned == "" then
            return nil, nil
        end

        local numericId = tonumber(cleaned)
        local userId = nil

        if numericId then
            userId = math.max(1, math.floor(numericId))
        else
            local ok, resolved = pcall(function()
                return Players:GetUserIdFromNameAsync(cleaned)
            end)

            if ok then
                userId = resolved
            end
        end

        if not userId or userId <= 0 then
            return nil, nil
        end

        local canonicalName = cleaned
        pcall(function()
            canonicalName = Players:GetNameFromUserIdAsync(userId)
        end)

        return userId, canonicalName
    end

    local function hideCharacterUntilAvatarApplied(character)
        local originalTransparency = {}
        local descendantConnection = nil
        local restored = false

        local function hidePart(instance)
            if instance:IsA("BasePart") then
                if originalTransparency[instance] == nil then
                    originalTransparency[instance] =
                        instance.LocalTransparencyModifier
                end

                instance.LocalTransparencyModifier = 1
            end
        end

        for _, descendant in ipairs(character:GetDescendants()) do
            hidePart(descendant)
        end

        descendantConnection = character.DescendantAdded:Connect(hidePart)

        return function()
            if restored then
                return
            end

            restored = true

            if descendantConnection then
                descendantConnection:Disconnect()
                descendantConnection = nil
            end

            for part, transparency in pairs(originalTransparency) do
                if part and part.Parent then
                    part.LocalTransparencyModifier = transparency
                end
            end
        end
    end

    local function applySavedAvatarState(character, hideUntilReady)
        if not character then
            return
        end

        avatarApplySerial = avatarApplySerial + 1
        local thisApply = avatarApplySerial
        local restoreVisibility = nil

        -- Hide the default avatar on the same frame CharacterAdded fires.
        -- The selected avatar is already cached, so it can replace the
        -- respawned appearance before the original avatar flashes onscreen.
        if hideUntilReady ~= false and targetAvatarUserId > 0 then
            restoreVisibility = hideCharacterUntilAvatarApplied(character)
        end

        task.spawn(function()
            pcall(function()
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                    or character:WaitForChild("Humanoid", 10)
                character:WaitForChild("Head", 10)

                if not humanoid
                or player.Character ~= character
                or thisApply ~= avatarApplySerial then
                    return
                end

                if targetAvatarUserId > 0 then
                    applyUserAvatar(character, targetAvatarUserId)
                else
                    getOwnBaseRightLegId()

                    if korbloxEnabled then
                        applyKorblox(character, true)
                    else
                        finishAvatarEffects(character)
                    end
                end
            end)

            RunService.RenderStepped:Wait()

            if restoreVisibility then
                restoreVisibility()
            end
        end)
    end

