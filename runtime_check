    local function ensureAccessoryAttached(character, accessory)
        if not character or not accessory then
            return false
        end

        local handle = accessory:FindFirstChild("Handle")
        if not handle or not handle:IsA("BasePart") then
            return false
        end

        handle.CanCollide = false
        handle.Massless = true

        if handle:FindFirstChild("AccessoryWeld")
        or handle:FindFirstChildWhichIsA("Weld") then
            return true
        end

        local handleAttachment = handle:FindFirstChildWhichIsA("Attachment")
        local targetAttachment = nil

        if handleAttachment then
            for _, descendant in ipairs(character:GetDescendants()) do
                if descendant:IsA("Attachment")
                and descendant.Name == handleAttachment.Name
                and not descendant:IsDescendantOf(accessory)
                and descendant.Parent
                and descendant.Parent:IsA("BasePart") then
                    targetAttachment = descendant
                    break
                end
            end
        end

        if not targetAttachment then
            local head = character:FindFirstChild("Head")
            targetAttachment = head
                and head:FindFirstChild("HatAttachment")
                or nil
        end

        if not targetAttachment
        or not targetAttachment.Parent
        or not targetAttachment.Parent:IsA("BasePart") then
            return false
        end

        local weld = Instance.new("Weld")
        weld.Name = "AccessoryWeld"
        weld.Part0 = handle
        weld.Part1 = targetAttachment.Parent
        weld.C0 = handleAttachment and handleAttachment.CFrame or CFrame.new()
        weld.C1 = targetAttachment.CFrame
        weld.Parent = handle
        return true
    end

    local function equipAccessory(character, accessoryName)
        local assetId = ACCESSORY_IDS[accessoryName]

        if not character or not assetId then
            return false
        end

        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then
            return false
        end

        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Accessory")
            and getAccessorySourceId(child) == assetId then
                child:SetAttribute("VeltrixAvatarAccessory", true)
                child:SetAttribute(
                    "VeltrixAvatarAccessoryName",
                    accessoryName
                )
                child:SetAttribute("VeltrixAvatarAccessoryId", assetId)
                return true
            end
        end

        local accessory = loadCatalogAccessory(assetId)
        if not accessory then
            return false
        end

        accessory:SetAttribute("VeltrixAvatarAccessory", true)
        accessory:SetAttribute(
            "VeltrixAvatarAccessoryName",
            accessoryName
        )
        accessory:SetAttribute("VeltrixAvatarAccessoryId", assetId)

        local added = pcall(function()
            if accessory:IsA("Accessory") then
                humanoid:AddAccessory(accessory)
            else
                accessory.Parent = character
            end
        end)

        if not added then
            accessory:Destroy()
            return false
        end

        task.wait()

        -- DevForum workaround for client-sided AddAccessory positioning.
        pcall(function()
            humanoid:BuildRigFromAttachments()
        end)

        task.wait()
        ensureAccessoryAttached(character, accessory)
        markEquippedAccessory(character, assetId, accessoryName)

        return accessory.Parent == character
            or accessory:IsDescendantOf(character)
    end

    local function cloneCurrentAccessories(character)
        local clones = {}

        if not character then
            return clones
        end

        for _, child in ipairs(character:GetChildren()) do
            local sourceId = getAccessorySourceId(child)

            if child:IsA("Accessory")
            and child:GetAttribute("VeltrixAvatarAccessory") ~= true
            and not REQUESTED_ACCESSORY_ID_SET[sourceId] then
                local oldArchivable = child.Archivable
                child.Archivable = true

                local ok, clone = pcall(function()
                    return child:Clone()
                end)

                child.Archivable = oldArchivable

                if ok and clone then
                    stripAccessoryJoints(clone)
                    clone:SetAttribute("VeltrixPreservedAccessory", true)
                    table.insert(clones, clone)
                end
            end
        end

        return clones
    end

    local function restoreAccessories(character, humanoid, clones)
        if not character or not humanoid then
            return
        end

        local restored = {}

        for _, clone in ipairs(clones or {}) do
            local cloneId = getAccessorySourceId(clone)
            local duplicate = nil

            for _, existing in ipairs(character:GetChildren()) do
                if existing:IsA("Accessory") then
                    local existingId = getAccessorySourceId(existing)
                    if (cloneId and existingId == cloneId)
                    or (not cloneId and existing.Name == clone.Name) then
                        duplicate = existing
                        break
                    end
                end
            end

            if duplicate then
                clone:Destroy()
            else
                stripAccessoryJoints(clone)

                local added = pcall(function()
                    if clone:IsA("Accessory") then
                        humanoid:AddAccessory(clone)
                    else
                        clone.Parent = character
                    end
                end)

                if added then
                    table.insert(restored, clone)
                else
                    clone:Destroy()
                end
            end
        end

        task.wait()
        pcall(function()
            humanoid:BuildRigFromAttachments()
        end)

        for _, accessory in ipairs(restored) do
            ensureAccessoryAttached(character, accessory)
        end
    end

    local function cleanCharacterAppearance(character)
        if not character then
            return
        end

        -- Match the working avatar changer: remove the current appearance
        -- before ApplyDescription so Roblox does not reject it because the
        -- live character no longer matches its previous description.
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Accessory")
            or child:IsA("Hat")
            or child:IsA("BodyColors")
            or child:IsA("CharacterMesh")
            or child:IsA("Shirt")
            or child:IsA("Pants")
            or child:IsA("ShirtGraphic") then
                child:Destroy()
            end
        end
    end

    local function setHeadless(character, enabled)
        if avatarHasNativeHeadless then
            return false
        end

        if not character then
            return false
        end

        local head = character:FindFirstChild("Head")
        if not head then
            return false
        end

        if enabled then
            if head:GetAttribute("VeltrixOriginalTransparency") == nil then
                head:SetAttribute(
                    "VeltrixOriginalTransparency",
                    head.Transparency
                )
            end
            head.Transparency = 1
        else
            local original = head:GetAttribute(
                "VeltrixOriginalTransparency"
            )
            head.Transparency =
                type(original) == "number" and original or 0
        end

        for _, descendant in ipairs(head:GetDescendants()) do
            if descendant:IsA("Decal")
            or descendant:IsA("Texture") then
                if enabled then
                    if descendant:GetAttribute(
                        "VeltrixOriginalTransparency"
                    ) == nil then
                        descendant:SetAttribute(
                            "VeltrixOriginalTransparency",
                            descendant.Transparency
                        )
                    end
                    descendant.Transparency = 1
                else
                    local original = descendant:GetAttribute(
                        "VeltrixOriginalTransparency"
                    )
                    descendant.Transparency =
                        type(original) == "number" and original or 0
                end
            end
        end

        return true
    end

