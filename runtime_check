        if offer and offer.Visible then
            local stroke = offer:FindFirstChild("OfferStroke")
            local icon = offer:FindFirstChild("PlusIcon")
            local message = offer:FindFirstChild("OfferMessage")
            local subscribe = offer:FindFirstChild("SubscribeText")
            local underline = subscribe and subscribe:FindFirstChild("Underline")

            if stroke then
                playTween(stroke, openDuration, { Transparency = 0.5 }, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
            end
            if icon then
                playTween(icon, openDuration, { TextTransparency = 0.1 }, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
            end
            if message then
                playTween(message, openDuration, { TextTransparency = 0.1 }, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
            end
            if subscribe then
