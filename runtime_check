        )
    local playerNameLabel =
        playerNameBg
        and playerNameBg:FindFirstChild(
            "PlayerNameLabel"
        )

    local itemFrame =
        contentFrame
        and contentFrame:FindFirstChild(
            "ItemFrame"
        )
    local itemImage =
        itemFrame
        and itemFrame:FindFirstChild(
            "ItemImage"
        )
    local itemNameBg =
