            end)
        end
    end

    local function forceBranchVisible(object, stopAt)
        local current = object
        while current and current ~= stopAt do
            if current:IsA("GuiObject") then
                pcall(function()
                    current.Visible = true
                end)
            end
            if current:IsA("CanvasGroup") then
                pcall(function()
                    current.GroupTransparency = 0
                    current.GroupColor3 = Color3.fromRGB(255, 255, 255)
                end)
            end
            current = current.Parent
        end
    end

    local function ensureContainer(parent, name, height, layoutOrder)
        if not parent then
            return nil
        end
        local object = parent:FindFirstChild(name)
        if not object then
            object = Instance.new("Frame")
            object.Name = name
            object.BackgroundTransparency = 1
            object.BorderSizePixel = 0
            object.Size = UDim2.new(1, 0, 0, height or 22)
            object.AutomaticSize = Enum.AutomaticSize.Y
            object.LayoutOrder = layoutOrder or 0
            object.Parent = parent
        end
        if object:IsA("GuiObject") then
            pcall(function()
                object.Visible = true
                if object.Size.Y.Offset == 0 and object.Size.Y.Scale == 0 then
                    object.Size = UDim2.new(object.Size.X.Scale, object.Size.X.Offset, 0, height or 22)
                end
            end)
        end
        return object
    end

