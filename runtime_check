    local function loadCatalogAccessory(assetId)
        -- Build a temporary R15 avatar containing the real catalog accessory.
        -- SetAccessories is more reliable than directly editing HatAccessory
        -- for rigid limiteds on current Roblox clients.
        local description = Instance.new("HumanoidDescription")
        local setOk = pcall(function()
            description:SetAccessories({
                {
                    AssetId = assetId,
                    AccessoryType = Enum.AccessoryType.Hat,
                    IsLayered = false,
                    Order = 1,
                },
            }, true)
        end)

        if not setOk then
            description.HatAccessory = tostring(assetId)
        end

        local temporaryModel = createModelFromDescription(
            description,
            Enum.HumanoidRigType.R15
        )
        description:Destroy()

        if temporaryModel then
            local sourceAccessory = temporaryModel:FindFirstChildWhichIsA(
                "Accessory",
                true
            )

            if sourceAccessory then
                local oldArchivable = sourceAccessory.Archivable
                sourceAccessory.Archivable = true

                local ok, clone = pcall(function()
                    return sourceAccessory:Clone()
                end)

                sourceAccessory.Archivable = oldArchivable
                temporaryModel:Destroy()

                if ok and clone then
                    stripAccessoryJoints(clone)
                    return clone
                end
            else
                temporaryModel:Destroy()
            end
        end

        -- Executor fallback. For catalog IDs, game:GetObjects normally
        -- returns the actual Accessory/Accoutrement rather than a decal.
        local ok, loaded = pcall(function()
            return game:GetObjects("rbxassetid://" .. tostring(assetId))
        end)

        if not ok or type(loaded) ~= "table" then
            return nil
        end

        local candidate = nil

        for _, root in ipairs(loaded) do
            candidate = findLoadedAccessory(root)
            if candidate then
                if candidate ~= root then
                    candidate.Parent = nil
                end
                break
            end
        end

        for _, root in ipairs(loaded) do
            if root ~= candidate then
                pcall(function()
                    root:Destroy()
                end)
            end
        end

        if candidate then
            stripAccessoryJoints(candidate)
        end

        return candidate
    end

    local function parseAccessoryIds(value)
        local result = {}

        for token in tostring(value or ""):gmatch("[^,%s]+") do
            local id = tonumber(token)
            if id and id > 0 then
                table.insert(result, math.floor(id))
            end
        end

        return result
    end

    local function serializeAccessoryIds(ids)
        local output = {}
        local seen = {}

        for _, id in ipairs(ids or {}) do
            id = tonumber(id)
            if id and id > 0 and not seen[id] then
                seen[id] = true
                table.insert(output, tostring(math.floor(id)))
            end
        end

        return table.concat(output, ",")
    end

    local function getAccessorySourceId(accessory)
