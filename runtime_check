        player = Players.LocalPlayer
    end
    if not player then
        return
    end

    local playerGui = player:WaitForChild("PlayerGui")
    local env = getgenv and getgenv() or _G
    local cleanupKey = "__FYNN_TREADMILL_PLUSONE_V38"

    if type(env[cleanupKey]) == "function" then
        pcall(env[cleanupKey])
    end

    local stopped = false
    local heartbeatConnection
    local active = {}
    local rng = Random.new()
    local lastSpawnAt = 0
    local currentKind = nil
    local nextResolveAt = 0
    local adminTarget = nil
    local candyTarget = nil

    local INTERVAL = 0.25
    local ICON = "rbxassetid://16408406294"

    local styles = {
        Admin = {
            text = "235.1M",
            color = Color3.fromRGB(255, 0, 0),
        },
        Candy = {
            text = "67.2M",
            color = Color3.fromRGB(255, 123, 204),
        },
    }

    local function resolveTargets(force)
        local now = os.clock()
        if not force and now < nextResolveAt then
            return
        end
        nextResolveAt = now + 1

        local treadmillFolder = Workspace:FindFirstChild("Treadmill")
        if not treadmillFolder then
            adminTarget = nil
            candyTarget = nil
            return
        end

        local admin = treadmillFolder:FindFirstChild("TreadmillAdmin")
        local candy = treadmillFolder:FindFirstChild("TreadmillCandy")

        adminTarget = admin and (admin:FindFirstChild("Conveyor") or admin:FindFirstChild("Conveyor", true)) or nil
        candyTarget = candy and (candy:FindFirstChild("Conveyor") or candy:FindFirstChild("Conveyor", true)) or nil
    end

    local function getTargetParts(target)
        local parts = {}
        if not target or not target.Parent then
            return parts
        end

        if target:IsA("BasePart") then
            parts[1] = target
            return parts
        end

        for _, item in ipairs(target:GetDescendants()) do
            if item:IsA("BasePart") then
                parts[#parts + 1] = item
            end
        end
        return parts
    end

    local function getCharacter()
        local character = player.Character
        if not character then
            return nil
        end

        local root = character:FindFirstChild("HumanoidRootPart")
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not root or not humanoid or humanoid.Health <= 0 then
            return nil
        end

        return character, root, humanoid
    end

    local function isStandingOn(target, character, root, humanoid)
        local targetParts = getTargetParts(target)
        if #targetParts == 0 then
            return false
        end

        -- Exact foot-over-surface check. This also works when CanTouch or CanQuery is disabled.
        local feet = root.Position - Vector3.new(
            0,
            math.max(0, humanoid.HipHeight) + (root.Size.Y * 0.5) - 0.35,
            0
        )

        for _, part in ipairs(targetParts) do
            if part.Parent then
                local localFeet = part.CFrame:PointToObjectSpace(feet)
                local half = part.Size * 0.5

                if math.abs(localFeet.X) <= half.X + 2.25
                    and math.abs(localFeet.Z) <= half.Z + 2.25
                    and localFeet.Y >= half.Y - 4
                    and localFeet.Y <= half.Y + 9 then
                    return true
                end
            end
        end

        -- Character overlap check for unusual treadmill geometry.
        local overlap = OverlapParams.new()
        overlap.FilterType = Enum.RaycastFilterType.Include
        overlap.FilterDescendantsInstances = {character}
        overlap.MaxParts = 100

        for _, part in ipairs(targetParts) do
            if part.Parent then
                local ok, hits = pcall(function()
                    return Workspace:GetPartBoundsInBox(
                        part.CFrame * CFrame.new(0, 2.5, 0),
                        part.Size + Vector3.new(4.5, 8, 4.5),
                        overlap
                    )
                end)
                if ok and hits and #hits > 0 then
                    return true
                end
            end
        end

        -- Downward ray fallback from several points around the player's feet.
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.FilterDescendantsInstances = {character}
        rayParams.IgnoreWater = true

        local right = root.CFrame.RightVector * 1.4
        local forward = root.CFrame.LookVector * 1.4
        local origins = {
            root.Position,
            root.Position + right,
            root.Position - right,
            root.Position + forward,
            root.Position - forward,
        }

        for _, origin in ipairs(origins) do
            local result = Workspace:Raycast(origin + Vector3.new(0, 2, 0), Vector3.new(0, -18, 0), rayParams)
            if result then
                for _, part in ipairs(targetParts) do
                    if result.Instance == part then
                        return true
                    end
                end
            end
        end

        return false
    end

    local function makePlusOne(style, root)
        if stopped or not root or not root.Parent then
            return
        end

        local billboard = Instance.new("BillboardGui")
        billboard.Name = "PlusOne"
        billboard.Adornee = root
        billboard.AlwaysOnTop = true
        billboard.LightInfluence = 0
        billboard.ResetOnSpawn = false
        billboard.Enabled = true
        billboard.MaxDistance = math.huge
        billboard.Size = UDim2.fromOffset(100, 33)
        billboard.ZIndexBehavior = Enum.ZIndexBehavior.Global

        local frame = Instance.new("Frame")
        frame.Name = "Frame"
        frame.AnchorPoint = Vector2.new(0.5, 0.5)
        frame.Position = UDim2.fromScale(0.5, 0.5)
        frame.Size = UDim2.fromScale(0, 0)
        frame.BackgroundTransparency = 1
        frame.BorderSizePixel = 0
        frame.Parent = billboard

        local layout = Instance.new("UIListLayout")
        layout.Name = "UIListLayout"
        layout.FillDirection = Enum.FillDirection.Horizontal
        layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        layout.VerticalAlignment = Enum.VerticalAlignment.Center
        layout.SortOrder = Enum.SortOrder.Name
        layout.Padding = UDim.new(0.05, 0)
        layout.Parent = frame

        local icon = Instance.new("ImageLabel")
        icon.Name = "ImageLabel"
        icon.LayoutOrder = 0
        icon.Size = UDim2.new(0.3, 0, 0.8, 0)
        icon.BackgroundTransparency = 1
        icon.BorderSizePixel = 0
        icon.Image = ICON
        icon.ImageColor3 = Color3.new(1, 1, 1)
        icon.ImageTransparency = 0
        icon.Parent = frame

        local aspect = Instance.new("UIAspectRatioConstraint")
        aspect.Name = "UIAspectRatioConstraint"
        aspect.AspectRatio = 1
        aspect.AspectType = Enum.AspectType.FitWithinMaxSize
        aspect.DominantAxis = Enum.DominantAxis.Width
        aspect.Parent = icon

        local label = Instance.new("TextLabel")
        label.Name = "TextLabel"
        label.LayoutOrder = 0
        label.Size = UDim2.new(0.6, 0, 0.9, 0)
        label.BackgroundTransparency = 1
        label.BorderSizePixel = 0
        label.Text = style.text
        label.TextColor3 = style.color
        label.TextTransparency = 0
        label.TextScaled = true
        label.TextWrapped = true
        label.Font = Enum.Font.GothamBlack
        label.Parent = frame

        local stroke = Instance.new("UIStroke")
        stroke.Name = "UIStroke"
        stroke.Color = Color3.new(0, 0, 0)
        stroke.Thickness = 2
        stroke.Transparency = 0
        stroke.LineJoinMode = Enum.LineJoinMode.Round
        stroke.Parent = label

        local x = rng:NextNumber(-3, 3)
        local z = rng:NextNumber(-2, 0)
        local startOffset = Vector3.new(x, 2.55, z)
        local highOffset = Vector3.new(x, rng:NextNumber(4.2, 5.2), z)
        billboard.StudsOffset = startOffset
        billboard.Parent = playerGui
        active[billboard] = true

        local grow = TweenService:Create(
            frame,
            TweenInfo.new(0.16, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            {Size = UDim2.fromScale(1.1, 1.1)}
        )
        local settle = TweenService:Create(
            frame,
            TweenInfo.new(0.20, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {Size = UDim2.fromScale(1, 1)}
        )
        local rise = TweenService:Create(
            billboard,
            TweenInfo.new(0.46, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {StudsOffset = highOffset}
        )

        grow:Play()
        rise:Play()

        task.delay(0.16, function()
            if billboard.Parent then
                settle:Play()
            end
        end)

        task.delay(0.46, function()
            if stopped or not billboard.Parent then
                return
            end

            TweenService:Create(
                billboard,
                TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                {StudsOffset = highOffset + Vector3.new(0, 0.8, 0)}
            ):Play()
            TweenService:Create(
                label,
                TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                {TextTransparency = 1}
            ):Play()
            TweenService:Create(
                icon,
                TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                {ImageTransparency = 1}
            ):Play()
            TweenService:Create(
                stroke,
                TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                {Transparency = 1}
            ):Play()
        end)

        task.delay(0.78, function()
            active[billboard] = nil
            if billboard.Parent then
                billboard:Destroy()
            end
        end)
    end

    resolveTargets(true)
    warn("[FYNN PlusOne] loaded. Admin target:", adminTarget, "Candy target:", candyTarget)

    heartbeatConnection = RunService.Heartbeat:Connect(function()
        if stopped then
            return
        end

        resolveTargets(false)
        local character, root, humanoid = getCharacter()
        if not character then
            currentKind = nil
            lastSpawnAt = 0
            return
        end

        local kind
        if adminTarget and isStandingOn(adminTarget, character, root, humanoid) then
            kind = "Admin"
        elseif candyTarget and isStandingOn(candyTarget, character, root, humanoid) then
            kind = "Candy"
        end

        if kind ~= currentKind then
            currentKind = kind
            lastSpawnAt = 0
            warn("[FYNN PlusOne] treadmill state:", kind or "none")
        end

        if not kind then
            return
        end

        local now = os.clock()
        if lastSpawnAt == 0 or now - lastSpawnAt >= INTERVAL then
            lastSpawnAt = now
            makePlusOne(styles[kind], root)
        end
    end)

    env[cleanupKey] = function()
        if stopped then
            return
        end
        stopped = true

        if heartbeatConnection then
            heartbeatConnection:Disconnect()
            heartbeatConnection = nil
        end

        for gui in pairs(active) do
            if gui and gui.Parent then
                gui:Destroy()
            end
            active[gui] = nil
        end

        env[cleanupKey] = nil
    end
end)

