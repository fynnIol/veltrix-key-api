local function moveFakePlayerControls(isOpen)
    local shift = isOpen and DROPDOWN_SHIFT or 0

    for name, baseY in pairs(fakeControlPositions) do
        local control = adminPanel:FindFirstChild(name)

        if control then
            playTween(control, 0.2, {
                Position = UDim2.new(
                    control.Position.X.Scale,
                    control.Position.X.Offset,
                    0,
                    baseY + shift
                ),
            }, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        end
    end
end

local function setOverheadListOpen(isOpen)
    if overheadListOpen == isOpen then
        return
    end

    overheadListOpen = isOpen

    if overheadDropdownTween then
        overheadDropdownTween:Cancel()
        overheadDropdownTween = nil
    end

    if isOpen then
        overheadListCorner.CornerRadius = UDim.new(0, 0)
        overheadDropdown.Visible = true
        overheadDropdown.Position = UDim2.fromOffset(0, 42)
        overheadDropdown.Size = UDim2.fromOffset(160, 0)
        refreshOverheadOptions()

        overheadDropdownTween = playTween(
            overheadDropdown,
            0.22,
            { Size = UDim2.fromOffset(160, DROPDOWN_HEIGHT) },
            Enum.EasingStyle.Quint,
            Enum.EasingDirection.Out
        )

        playTween(
            overheadListButton,
            0.22,
            { Size = UDim2.fromOffset(160, 42 + DROPDOWN_HEIGHT) },
            Enum.EasingStyle.Quint,
            Enum.EasingDirection.Out
        )
    else
        overheadDropdownTween = playTween(
            overheadDropdown,
            0.18,
            { Size = UDim2.fromOffset(160, 0) },
            Enum.EasingStyle.Quart,
            Enum.EasingDirection.In
        )

        playTween(
            overheadListButton,
            0.18,
            { Size = UDim2.fromOffset(160, 42) },
            Enum.EasingStyle.Quart,
            Enum.EasingDirection.In
        )

        local closingTween = overheadDropdownTween

        closingTween.Completed:Connect(function()
            if overheadDropdownTween == closingTween
            and not overheadListOpen then
                overheadDropdown.Visible = false
                overheadDropdown.Position = UDim2.fromOffset(0, 42)
                overheadListCorner.CornerRadius = UDim.new(0, 9)
            end
        end)
    end

    if not adminPanel:GetAttribute("FYNNTabbedAdmin") then
        local targetHeight = isOpen
            and PANEL_EXPANDED_HEIGHT
            or PANEL_COLLAPSED_HEIGHT

        local centerShift = isOpen
            and (DROPDOWN_SHIFT / 2)
            or -(DROPDOWN_SHIFT / 2)

        playTween(adminPanel, 0.22, {
            Size = UDim2.fromOffset(288, targetHeight),
            Position = UDim2.new(
                adminPanel.Position.X.Scale,
                adminPanel.Position.X.Offset,
                adminPanel.Position.Y.Scale,
                adminPanel.Position.Y.Offset + centerShift
            ),
        }, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

        moveFakePlayerControls(isOpen)
    end
    refreshOverheadListButton()
end

