local function getSpawnCFrame()
    local spawnPart = workspace:FindFirstChild("SpawnLocation")

    if spawnPart and spawnPart:IsA("BasePart") then
        local halfX = math.max(2, spawnPart.Size.X * 0.43)
        local halfZ = math.max(2, spawnPart.Size.Z * 0.43)
        local angle = fakeRandom:NextNumber(0, math.pi * 2)
        local radius = fakeRandom:NextNumber(
            1.5,
            math.max(2, math.min(halfX, halfZ))
        )

        local localX = math.clamp(
            math.cos(angle) * radius,
            -halfX,
            halfX
        )
        local localZ = math.clamp(
            math.sin(angle) * radius,
            -halfZ,
            halfZ
        )

        local position = spawnPart.CFrame:PointToWorldSpace(
            Vector3.new(
                localX,
                spawnPart.Size.Y * 0.5 + 3.2,
                localZ
            )
        )

        return CFrame.new(position)
            * CFrame.Angles(
                0,
                fakeRandom:NextNumber(0, math.pi * 2),
                0
            )
    end

    local root = player.Character
        and player.Character:FindFirstChild("HumanoidRootPart")

    if root then
        return root.CFrame
            * CFrame.new(
                fakeRandom:NextNumber(-8, 8),
                2,
                fakeRandom:NextNumber(-8, 8)
            )
    end

    return CFrame.new(0, 8, 0)
end

local function loadAnimationTrack(
    animator,
    animationId,
    looped,
    priority
)
    local numericId = tonumber(animationId)

    if not numericId or numericId <= 0 then
        return nil
    end

    local animation = Instance.new("Animation")
    animation.AnimationId = "rbxassetid://" .. tostring(numericId)

    local ok, track = pcall(function()
        return animator:LoadAnimation(animation)
    end)

    animation:Destroy()

    if not ok or not track then
        return nil
    end

    track.Looped = looped
    track.Priority = priority

    return track
end

local function setupFakeAnimations(
    model,
    humanoid,
    description
)
    local animator = humanoid:FindFirstChildOfClass("Animator")

    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = humanoid
    end

    -- Roblox Rthro animation set.
    local idleTrack = loadAnimationTrack(
        animator,
        2510196951,
        true,
        Enum.AnimationPriority.Idle
    )
    local walkTrack = loadAnimationTrack(
        animator,
        2510202577,
        true,
        Enum.AnimationPriority.Movement
    )
    local runTrack = loadAnimationTrack(
        animator,
        2510198475,
        true,
        Enum.AnimationPriority.Movement
    )
    local jumpTrack = loadAnimationTrack(
        animator,
        2510197830,
        false,
        Enum.AnimationPriority.Action
    )
    local fallTrack = loadAnimationTrack(
        animator,
        2510195892,
        true,
        Enum.AnimationPriority.Action
    )

    local activeMovementTrack = nil

    if idleTrack then
        idleTrack:Play(0.15)
    end

    humanoid.Running:Connect(function(speed)
        if not model.Parent then
            return
        end

        if speed > 0.5 then
            if idleTrack and idleTrack.IsPlaying then
                idleTrack:Stop(0.12)
            end

            if fallTrack and fallTrack.IsPlaying then
                fallTrack:Stop(0.08)
            end

            local wantedTrack

            if speed >= 18 then
                wantedTrack = runTrack or walkTrack
            else
                wantedTrack = walkTrack or runTrack
            end

            if activeMovementTrack ~= wantedTrack then
                if activeMovementTrack
                and activeMovementTrack.IsPlaying then
                    activeMovementTrack:Stop(0.12)
                end

                activeMovementTrack = wantedTrack

                if activeMovementTrack then
                    activeMovementTrack:Play(0.12)
                end
            elseif activeMovementTrack
            and not activeMovementTrack.IsPlaying then
                activeMovementTrack:Play(0.12)
            end

            if activeMovementTrack then
                activeMovementTrack:AdjustSpeed(
                    math.clamp(speed / 16, 0.8, 1.75)
                )
            end
        else
            if activeMovementTrack
            and activeMovementTrack.IsPlaying then
                activeMovementTrack:Stop(0.12)
            end

            activeMovementTrack = nil

            if idleTrack and not idleTrack.IsPlaying then
                idleTrack:Play(0.12)
            end
        end
    end)

    humanoid.StateChanged:Connect(function(_, newState)
        if not model.Parent then
            return
        end

        if newState == Enum.HumanoidStateType.Jumping then
            if jumpTrack then
                jumpTrack:Play(0.06)
            end
        elseif newState == Enum.HumanoidStateType.Freefall then
            if fallTrack and not fallTrack.IsPlaying then
                fallTrack:Play(0.08)
            end
        elseif newState == Enum.HumanoidStateType.Landed
        or newState == Enum.HumanoidStateType.Running then
            if fallTrack and fallTrack.IsPlaying then
                fallTrack:Stop(0.08)
            end
        end
    end)
end

local historyAccumulator = 0

local fakeHistoryConnection =
    RunService.Heartbeat:Connect(function(deltaTime)
        historyAccumulator += deltaTime

        if historyAccumulator < 0.08 then
            return
        end

        historyAccumulator = 0

        local root = player.Character
            and player.Character:FindFirstChild("HumanoidRootPart")

        if not root then
            return
        end

        local now = os.clock()

        table.insert(positionHistory, {
            Time = now,
            Position = root.Position,
        })

        while #positionHistory > 0
        and now - positionHistory[1].Time > 3.5 do
            table.remove(positionHistory, 1)
        end
    end)

local function getDelayedPlayerPosition(delaySeconds)
    if #positionHistory == 0 then
        local root = player.Character
            and player.Character:FindFirstChild("HumanoidRootPart")

        return root and root.Position or nil
    end

    local targetTime = os.clock() - delaySeconds

    for index = #positionHistory, 1, -1 do
        local entry = positionHistory[index]

        if entry.Time <= targetTime then
            return entry.Position
        end
    end

    return positionHistory[1].Position
end

