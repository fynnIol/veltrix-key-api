local outlineAnimationConnection =
    RunService.RenderStepped:Connect(function(deltaTime)
        for index = #animatedOutlineGradients, 1, -1 do
            local gradient = animatedOutlineGradients[index]

            if not gradient or not gradient.Parent then
                table.remove(animatedOutlineGradients, index)
            elseif gradient.Name == "SelectedGradient" then
                gradient.Offset = Vector2.new(
                    math.sin(os.clock() * 2.8) * 0.7,
                    0
                )
                gradient.Rotation = 0
            else
                gradient.Rotation =
                    (gradient.Rotation + deltaTime * 95) % 360
            end
        end
    end)

local function getSelectedGradient(button)
    local gradient = button:FindFirstChild("SelectedGradient")

    if gradient then
        return gradient
    end

    gradient = Instance.new("UIGradient")
    gradient.Name = "SelectedGradient"
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(5, 5, 5)),
        ColorSequenceKeypoint.new(0.22, Color3.fromRGB(55, 55, 55)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(245, 245, 245)),
        ColorSequenceKeypoint.new(0.78, Color3.fromRGB(55, 55, 55)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(5, 5, 5)),
    })
    gradient.Transparency = NumberSequence.new(1)
    gradient.Rotation = 0
    gradient.Parent = button

    table.insert(animatedOutlineGradients, gradient)

    return gradient
end

local function setAnimatedSelected(button, enabled)
    local gradient = getSelectedGradient(button)

