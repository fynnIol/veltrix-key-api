    local function formatNumber(value)
        value = math.max(0, math.floor(tonumber(value) or 0))
        local textValue = tostring(value)
        while true do
            local changed
            textValue, changed = textValue:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
            if changed == 0 then
                break
            end
        end
        return textValue
    end

    local function parseNumber(value)
        if type(value) ~= "string" then
            return 0
        end
        local clean = value:gsub("<.->", ""):gsub("[^%d]", "")
        return tonumber(clean) or 0
    end

    local function applyThumbnail(target)
        local imageObject = exactPath(target.names)
        if not imageObject or not (imageObject:IsA("ImageLabel") or imageObject:IsA("ImageButton")) then
            return
        end

        pcall(function()
            if imageObject.Image ~= target.image then
                imageObject.Image = target.image
            end
            imageObject.ImageColor3 = Color3.fromRGB(255, 255, 255)
            imageObject.ImageTransparency = 0
            imageObject.ImageRectOffset = Vector2.zero
            imageObject.ImageRectSize = Vector2.zero
            imageObject.Visible = true
        end)
    end

    local function applyThumbnails()
