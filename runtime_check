            end
            if underline then
                playTween(underline, openDuration, { BackgroundTransparency = 0.1 }, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
            end
        end
    end

    if modalMode == "complete" then
        playTween(
            actionButton,
            openDuration,
            { BackgroundTransparency = 0 },
            Enum.EasingStyle.Quint,
            Enum.EasingDirection.Out
        )

        playTween(
            actionText,
            openDuration,
            { TextTransparency = 0 },
            Enum.EasingStyle.Quint,
            Enum.EasingDirection.Out
        )
    end

    local function finishOpening()
        if openingToken ~= modalOpeningToken
        or not modalOpen
        or closing then
            return
        end

        modalOpeningTween = nil
        main.Position = UDim2.fromScale(0.5, 0.5)
        main.BackgroundTransparency = 0

        if modalMode == "purchase" then
            actionButton.BackgroundTransparency = 0.3

            playTween(
                actionButton,
                0.2,
                { BackgroundTransparency = 0 },
                Enum.EasingStyle.Sine,
                Enum.EasingDirection.Out
            )

            playTween(
                actionText,
                0.2,
                { TextTransparency = 0 },
                Enum.EasingStyle.Sine,
                Enum.EasingDirection.Out
            )

            startPurchaseFill()
        elseif modalMode == "error" then
            playTween(
                actionButton,
                0.2,
                { BackgroundTransparency = 0 },
                Enum.EasingStyle.Sine,
                Enum.EasingDirection.Out
            )

            playTween(
                actionText,
                0.2,
                { TextTransparency = 0 },
                Enum.EasingStyle.Sine,
                Enum.EasingDirection.Out
            )
        end
    end

    modalOpeningTween = TweenService:Create(
        main,
        TweenInfo.new(
            openDuration,
            Enum.EasingStyle.Quint,
            Enum.EasingDirection.Out
        ),
        {
            Position = UDim2.fromScale(0.5, 0.5),
            BackgroundTransparency = 0,
        }
    )

    modalOpeningTween.Completed:Connect(function(playbackState)
        if playbackState == Enum.PlaybackState.Completed then
            finishOpening()
        end
    end)

    modalOpeningTween:Play()
end

