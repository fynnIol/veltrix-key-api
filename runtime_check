    local panelTransitioning = false
    adminPanel.Visible = true

    local function setMobileToggleVisible(isVisible, instant)
        if isVisible then
            mobileToggleButton.Visible = true

            if instant then
                mobileToggleButton.BackgroundTransparency = 0
                mobileToggleLogo.ImageTransparency = 0
                mobileToggleStroke.Transparency = 0
                mobileToggleButton.Size = UDim2.fromOffset(46, 46)
                mobileToggleButton.Position = UDim2.new(0.5, 0, 0, 62)
            else
                mobileToggleButton.BackgroundTransparency = 1
                mobileToggleLogo.ImageTransparency = 1
                mobileToggleStroke.Transparency = 1
                mobileToggleButton.Size = UDim2.fromOffset(40, 40)
                mobileToggleButton.Position = UDim2.new(0.5, 0, 0, 54)

                playTween(mobileToggleButton, 0.18, {
                    BackgroundTransparency = 0,
                    Size = UDim2.fromOffset(46, 46),
                    Position = UDim2.new(0.5, 0, 0, 62),
                }, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

                playTween(mobileToggleLogo, 0.16, {
                    ImageTransparency = 0,
                })

                playTween(mobileToggleStroke, 0.16, {
                    Transparency = 0,
                })
            end
        else
            local hideTween = playTween(mobileToggleButton, instant and 0 or 0.16, {
                BackgroundTransparency = 1,
                Size = UDim2.fromOffset(40, 40),
                Position = UDim2.new(0.5, 0, 0, 54),
            }, Enum.EasingStyle.Quart, Enum.EasingDirection.In)

            playTween(mobileToggleLogo, instant and 0 or 0.12, {
                ImageTransparency = 1,
            })

            playTween(mobileToggleStroke, instant and 0 or 0.12, {
                Transparency = 1,
            })

            hideTween.Completed:Connect(function()
                if mobilePanelOpen then
                    mobileToggleButton.Visible = false
                end
            end)
        end
    end

    local function setMobilePanelOpen(isOpen)
        if panelTransitioning or mobilePanelOpen == isOpen then
            return
        end

        panelTransitioning = true
        mobilePanelOpen = isOpen

        if isOpen then
            setMobileToggleVisible(false, false)
            adminPanel.Visible = true
            adminPanelScale.Scale = 0.84
            adminFadeCover.BackgroundTransparency = 0
            adminStroke.Transparency = 1

            local scaleTween = playTween(
                adminPanelScale,
                0.22,
                { Scale = 1 },
                Enum.EasingStyle.Quint,
                Enum.EasingDirection.Out
            )

            playTween(adminFadeCover, 0.18, {
                BackgroundTransparency = 1,
            }, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

            playTween(adminStroke, 0.18, {
                Transparency = 0,
            }, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

            scaleTween.Completed:Connect(function()
                panelTransitioning = false
            end)
        else
            setOverheadListOpen(false)
            adminFadeCover.BackgroundTransparency = 1

            local closeTween = playTween(
                adminPanelScale,
                0.18,
                { Scale = 0.84 },
                Enum.EasingStyle.Quint,
                Enum.EasingDirection.In
            )

            playTween(adminFadeCover, 0.16, {
                BackgroundTransparency = 0,
            }, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

            playTween(adminStroke, 0.16, {
                Transparency = 1,
            }, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

            closeTween.Completed:Connect(function()
                if not mobilePanelOpen then
                    adminPanel.Visible = false
                    adminPanelScale.Scale = 1
                    adminFadeCover.BackgroundTransparency = 1
                    adminStroke.Transparency = 0
                    setMobileToggleVisible(true, false)
                end

                panelTransitioning = false
            end)
        end
    end

    adminCloseButton.Activated:Connect(function()
        setMobilePanelOpen(false)
    end)

    mobileToggleButton.MouseButton1Down:Connect(function()
        playTween(mobileToggleButton, 0.08, {
