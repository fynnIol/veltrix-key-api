        local offer = main:FindFirstChild("RobloxPlusOffer")

        if offer and offer.Visible then
            local stroke = offer:FindFirstChild("OfferStroke")
            local icon = offer:FindFirstChild("PlusIcon")
            local message = offer:FindFirstChild("OfferMessage")
            local subscribe = offer:FindFirstChild("SubscribeText")
