local function trimText(value)
    return tostring(value or "")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
end

local function normalizeItemName(value)
    return trimText(value)
        :lower()
        :gsub("%s+", " ")
end

local function updateCurrentProduct(
    itemNameLabel,
    itemImage
)
    local itemName =
        itemNameLabel
        and trimText(itemNameLabel.Text)
        or ""

    if itemName == "" then
        itemName = "PRODUCT_NAME"
    end

    local itemKey =
        normalizeItemName(itemName)
            :gsub("[^%a%d]", "")
    local itemInfo = ITEM_PRICES[itemKey]

    if not itemInfo then
        for knownName, knownInfo in pairs(ITEM_PRICES) do
            if itemKey:sub(1, #knownName) == knownName then
                itemInfo = knownInfo
                break
            end
        end
    end

    if itemInfo then
        PRODUCT_NAME = itemInfo.name or itemName
        PRODUCT_PRICE_VALUE = itemInfo.price or 0
        PRODUCT_PRICE_IS_ROBUX = itemInfo.price ~= nil
        PRODUCT_PRICE_TEXT =
            itemInfo.price
            and formatWithCommas(itemInfo.price)
            or itemInfo.priceText
            or "PRICE"
    else
        PRODUCT_NAME = itemName
        PRODUCT_PRICE_VALUE = 0
        PRODUCT_PRICE_IS_ROBUX = true
        PRODUCT_PRICE_TEXT = "PRICE"
    end

    if itemImage
    and (itemImage:IsA("ImageLabel")
        or itemImage:IsA("ImageButton")) then
        PRODUCT_IMAGE = itemImage.Image or ""
        PRODUCT_IMAGE_RECT_OFFSET =
            itemImage.ImageRectOffset
        PRODUCT_IMAGE_RECT_SIZE =
            itemImage.ImageRectSize
        PRODUCT_IMAGE_COLOR =
            itemImage.ImageColor3
    else
        PRODUCT_IMAGE = ""
        PRODUCT_IMAGE_RECT_OFFSET =
            Vector2.new(0, 0)
        PRODUCT_IMAGE_RECT_SIZE =
            Vector2.new(0, 0)
        PRODUCT_IMAGE_COLOR =
            Color3.new(1, 1, 1)
    end
end

