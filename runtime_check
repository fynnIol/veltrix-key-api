    local function saveEquippedAvatarAccessories()
        local equippedList = {}

        for _, accessoryName in ipairs(ACCESSORY_ORDER) do
            if equippedAvatarAccessories[accessoryName] then
                table.insert(equippedList, accessoryName)
            end
        end

        Settings.Data.AvatarSelection = avatarSelection
        Settings.Data.AvatarEquippedList = equippedList
        Settings.Data.AvatarEquipped = equippedList[1] or ""
        Settings:Save()

        local bridgeEnv = getgenv and getgenv() or _G
        if type(bridgeEnv.__FYNN_SET_INSPECT_ACCESSORIES) == "function" then
            pcall(bridgeEnv.__FYNN_SET_INSPECT_ACCESSORIES, equippedList)
        end
