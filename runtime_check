        and mainFrame:FindFirstChild(
            "SendGiftButtonFrame"
        )
    local sendGiftButton =
        sendGiftButtonFrame
        and sendGiftButtonFrame:FindFirstChild(
            "SendGiftButton"
        )

    return playerNameLabel,
        sendGiftButton,
        itemImage,
        itemNameLabel
end

local function handleSendGiftPressed(
    pressedButton,
    playerNameLabel,
    itemImage,
    itemNameLabel
)
    if triggerBusy
    or pressedButton ~= watchedSendGiftButton then
        return
    end

    -- Do not show the custom purchase modal until a player
    -- has actually been selected in the gift modal.
    if not playerNameLabel
    or trimText(playerNameLabel.Text) == "" then
        return
    end

    -- Save the selected username for the final confirmation.
    selectedGiftUsername =
        trimText(playerNameLabel.Text)

    -- Read the item immediately. The game's original button
    -- callback may hide or destroy its gift modal afterward.
    updateCurrentProduct(
        itemNameLabel,
        itemImage
    )

    triggerBusy = true

    task.delay(0.3, function()
        if not modalOpen and not closing then
            openModal("purchase")
        end

        task.delay(0.2, function()
            triggerBusy = false
        end)
    end)
end

task.spawn(function()
    while screenGui.Parent do
        local playerNameLabel,
            sendGiftButton,
            itemImage,
            itemNameLabel = getGiftControls()

        if sendGiftButton
            ~= watchedSendGiftButton then
            if sendGiftConnection then
                sendGiftConnection:Disconnect()
                sendGiftConnection = nil
            end

            watchedSendGiftButton =
                sendGiftButton

            if watchedSendGiftButton
            and watchedSendGiftButton:IsA(
                "GuiButton"
            ) then
                local connectedButton =
                    watchedSendGiftButton
                local connectedPlayerNameLabel =
                    playerNameLabel
                local connectedItemImage =
                    itemImage
                local connectedItemNameLabel =
                    itemNameLabel

                sendGiftConnection =
                    connectedButton.Activated:Connect(
                        function()
                            handleSendGiftPressed(
                                connectedButton,
                                connectedPlayerNameLabel,
                                connectedItemImage,
                                connectedItemNameLabel
                            )
                        end
                    )
            end
        end

        task.wait(0.2)
    end

    if sendGiftConnection then
        sendGiftConnection:Disconnect()
    end
end)

-- Treadmill Already-Owned Error Trigger

local treadmillButtonConnections = {}
local treadmillErrorBusy = false

local function getTreadmillShopButtons()
    local buttons = {}
    local playerGui = player:FindFirstChild("PlayerGui")
    local speedGameUI =
        playerGui
        and playerGui:FindFirstChild("SpeedGameUI")
    local modals =
        speedGameUI
        and speedGameUI:FindFirstChild("Modals")
    local shopModal =
        modals
        and modals:FindFirstChild("RobuxShopModal")
    local scrollingFrame =
        shopModal
        and shopModal:FindFirstChild("ScrollingFrame")
    local treadmills =
        scrollingFrame
        and scrollingFrame:FindFirstChild("Treadmills")
    local mainFrame =
        treadmills
        and treadmills:FindFirstChild("MainFrame")

    if not mainFrame then
        return buttons
    end

    local function addButton(containerName, preferContainer)
        local container = mainFrame:FindFirstChild(containerName)

        if not container then
            return
        end

        local button = nil

        if preferContainer
        and container:IsA("GuiButton") then
            button = container
        else
            button = container:FindFirstChild("Buy")

            if not button then
                button = container:FindFirstChild("Buy", true)
            end

            if not button
            and container:IsA("GuiButton") then
                button = container
            end
        end

        if button and button:IsA("GuiButton") then
            table.insert(buttons, button)
        end
    end

    addButton("Admin", false)
    addButton("Candy", false)
    addButton("Gold", true)
    addButton("Diamond", true)

    return buttons
end

local function showAlreadyOwnedError()
    if treadmillErrorBusy then
        return
    end

    treadmillErrorBusy = true

    task.delay(0.3, function()
        local function openError()
            if not modalOpen and not closing then
                openModal("error")
            end

            task.delay(0.2, function()
                treadmillErrorBusy = false
            end)
        end

        if modalOpen and not closing then
            closeModal(openError)
        elseif not closing then
            openError()
        else
            treadmillErrorBusy = false
        end
    end)
end

task.spawn(function()
    while screenGui.Parent do
        local currentButtons = {}

        for _, button in ipairs(
            getTreadmillShopButtons()
        ) do
            currentButtons[button] = true

            if not treadmillButtonConnections[button] then
                treadmillButtonConnections[button] =
                    button.Activated:Connect(function()
                        showAlreadyOwnedError()
                    end)
            end
        end

        for button, connection in pairs(
            treadmillButtonConnections
        ) do
            if not currentButtons[button]
            or not button.Parent then
                connection:Disconnect()
                treadmillButtonConnections[button] = nil
            end
        end

        task.wait(0.1)
    end

    for button, connection in pairs(
        treadmillButtonConnections
    ) do
        connection:Disconnect()
        treadmillButtonConnections[button] = nil
    end
end)

