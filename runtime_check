            Position = UDim2.new(0.5, 0, 0, 62),
        })
    end)

    mobileToggleButton.Activated:Connect(function()
        setMobilePanelOpen(true)
    end)

    if UserInputService.TouchEnabled then
        setMobileToggleVisible(true, true)

        task.delay(1.15, function()
            if mobilePanelOpen then
                setMobileToggleVisible(false, false)
            end
        end)
    else
        mobileToggleButton.Visible = false
    end


    task.defer(function()
        if not adminPanel.Visible then
            return
        end

        adminPanelScale.Scale = 0.84
        adminFadeCover.BackgroundTransparency = 0
        adminStroke.Transparency = 1

        playTween(
            adminPanelScale,
            0.22,
            { Scale = 1 },
            Enum.EasingStyle.Quint,
            Enum.EasingDirection.Out
        )

        playTween(
            adminFadeCover,
            0.18,
            { BackgroundTransparency = 1 },
            Enum.EasingStyle.Quad,
            Enum.EasingDirection.Out
        )

        playTween(
            adminStroke,
            0.18,
            { Transparency = 0 },
            Enum.EasingStyle.Quad,
            Enum.EasingDirection.Out
        )
    end)
